{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Outreach Draft Output",
  "type": "object",
  "required": ["run_date", "counts", "drafts", "notes"],
  "properties": {
    "run_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "counts": {
      "type": "object",
      "required": ["contacts_input", "drafts_created", "drafts_skipped_dedupe"],
      "properties": {
        "contacts_input": { "type": "integer", "minimum": 0 },
        "drafts_created": { "type": "integer", "minimum": 0 },
        "drafts_skipped_dedupe": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "drafts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["company", "contact", "title", "angle", "message", "call_to_action", "confidence_score"],
        "properties": {
          "company": { "type": "string", "minLength": 1 },
          "contact": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "angle": { "type": "string", "enum": ["pipeline_visibility", "crm_adoption", "lead_quality", "sales_cycle_speed", "forecast_accuracy", "custom"] },
          "pain_signal": { "type": "string" },
          "message": { "type": "string", "minLength": 40 },
          "call_to_action": { "type": "string", "minLength": 5 },
          "confidence_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "dedupe_key": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "object",
      "required": ["blockers", "quality_flags"],
      "properties": {
        "blockers": { "type": "array", "items": { "type": "string" } },
        "quality_flags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
