": \"call_Z4OOsROftmVnYYu4bNp05hTI|fc_016894fb01b951d60169a8c34081448193955728b421ccb480\",\n          \"name\": \"exec\",\n          \"arguments\": {\n            \"command\": \"$script = @'\\n$src = \\\"C:\\\\Users\\\\tonyb\\\\.openclaw\\\\workspace\\\"\\n$drive = \\\"G:\\\\My Drive\\\\openclaw-workspace-main\\\"\\n$log = \\\"C:\\\\Users\\\\tonyb\\\\.openclaw\\\\workspace\\\\sync-monitor.log\\\"\\n\\nfunction Get-Count($path, $recurse=$false){\\n  if(!(Test-Path $path)){ return -1 }\\n  if($recurse){ return (Get-ChildItem $path -Recurse -Force -ErrorAction SilentlyContinue | Measure-Object).Count }\\n  else { return (Get-ChildItem $path -Force -ErrorAction SilentlyContinue | Measure-Object).Count }\\n}\\n\\n\\\"[$(Get-Date -Format s)] monitor started\\\" | Out-File -FilePath $log -Encoding utf8 -Append\\n\\nfor($i=0; $i -lt 72; $i++){\\n  if(!(Test-Path $drive)){\\n    \\\"[$(Get-Date -Format s)] drive not found\\\" | Out-File -FilePath $log -Append\\n    Start-Sleep -Seconds 60\\n    continue\\n  }\\n\\n  # keep pushing latest desktop workspace to Drive (except active large zip)\\n  robocopy $src $drive /MIR /XF openclaw_backup_20260304_1536.zip /R:1 /W:1 /NFL /NDL /NP /NJH /NJS | Out-Null\\n\\n  $sTop = Get-Count $src $false\\n  $sRec = Get-Count $src $true\\n  $dTop = Get-Count $drive $false\\n  $dRec = Get-Count $drive $true\\n\\n  \\\"[$(Get-Date -Format s)] src($sTop/$sRec) drive($dTop/$dRec)\\\" | Out-File -FilePath $log -Append\\n\\n  # consider hydrated when counts are close/equal to source\\n  if($dTop -ge $sTop -and $dRec -ge $sRec){\\n    # final mirror from Drive back to workspace to normalize\\n    robocopy $drive $src /MIR /R:1 /W:1 /NFL /NDL /NP /NJH /NJS | Out-Null\\n    $fTop = Get-Count $src $false\\n    $fRec = Get-Count $src $true\\n    \\\"[$(Get-Date -Format s)] FINALIZED workspace($fTop/$fRec)\\\" | Out-File -FilePath $log -Append\\n    break\\n  }\\n\\n  Start-Sleep -Seconds 60\\n}\\n\\n\\\"[$(Get-Date -Format s)] monitor exit\\\" | Out-File -FilePath $log -Append\\n'@;\\n$path = \\\"C:\\\\Users\\\\tonyb\\\\.openclaw\\\\workspace\\\\sync-monitor.ps1\\\";\\nSet-Content -Path $path -Value $script -Encoding utf8;\\nStart-Process -FilePath powershell -ArgumentList \\\"-NoProfile -ExecutionPolicy Bypass -File `\\\"$path`\\\"\\\" -WindowStyle Hidden;\\nWrite-Output \\\"SYNC_MONITOR_STARTED\\\"\",\n            \"workdir\": \"C:\\\\Users\\\\tonyb\\\\.openclaw\\\\workspace\",\n            \"yieldMs\": 120000\n          },\n          \"partialJson\": \"{\\\"command\\\":\\\"$script = @'\\\\n$src = \\\\\\\"C:\\\\\\\\Users\\\\\\\\tonyb\\\\\\\\.openclaw\\\\\\\\workspace\\\\\\\"\\\\n$drive = \\\\\\\"G:\\\\\\\\My Drive\\\\\\\\openclaw-workspace-main\\\\\\\"\\\\n$log = \\\\\\\"C:\\\\\\\\Users\\\\\\\\tonyb\\\\\\\\.openclaw\\\\\\\\workspace\\\\\\\\sync-monitor.log\\\\\\\"\\\\n\\\\nfunction Get-Count($path, $recurse=$false){\\\\n  if(!(Test-Path $path)){ return -1 }\\\\n  if($recurse){ return (Get-ChildItem $path -Recurse -Force -ErrorAction SilentlyContinue | Measure-Object).Count }\\\\n  else { return (Get-ChildItem $path -Force -ErrorAction SilentlyContinue | Measure-Object).Count }\\\\n}\\\\n\\\\n\\\\\\\"[$(Get-Date -Format s)] monitor started\\\\\\\" | Out-File -FilePath $log -Encoding utf8 -Append\\\\n\\\\nfor($i=0; $i -lt 72; $i++){\\\\n  if(!(Test-Path $drive)){\\\\n    \\\\\\\"[$(Get-Date -Format s)] drive not found\\\\\\\" | Out-File -FilePath $log -Append\\\\n    Start-Sleep -Seconds 60\\\\n    continue\\\\n  }\\\\n\\\\n  # keep pushing latest desktop workspace to Drive (except active large zip)\\\\n  robocopy $src $drive /MIR /XF openclaw_backup_20260304_1536.zip /R:1 /W:1 /NFL /NDL /NP /NJH /NJS | Out-Null\\\\n\\\\n  $sTop = Get-Count $src $false\\\\n  $sRec = Get-Count $src $true\\\\n  $dTop = Get-Count $drive $false\\\\n  $dRec = Get-Count $drive $true\\\\n\\\\n  \\\\\\\"[$(Get-Date -Format s)] src($sTop/$sRec) drive($dTop/$dRec)\\\\\\\" | Out-File -FilePath $log -Append\\\\n\\\\n  # consider hydrated whe