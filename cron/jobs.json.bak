        "lastRunAtMs": 1773077735578,
        "lastRunStatus": "error",
        "lastStatus": "error",
        "lastDurationMs": 39
      },
      "name": "Cron: 0 7 * * *",
      "enabled": true,
      "wakeMode": "now",
      "sessionTarget": "main"
    },
