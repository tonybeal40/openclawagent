      "schedule": {
        "kind": "cron",
        "expr": "0 23 * * *",
        "tz": "America/Chicago"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "thinking": "low",
        "timeoutSeconds": 1800,
        "message": "Nightly pipeline reminder: run the full overnight pipeline with artifact verification.\n\nRequired execution targets:\n- Run/refresh mission control, job pipeline, company research, trend scan, and lead outputs.\n- Prioritize writing real artifacts under: outputs/, deliverables/, OpenClawMissionControl/.\n\nRequired proof (must include all):\n1) Enumerate changed files with exact path + last write time + file size.\n2) Count total changed files in this run window.\n3) If fewer than 5 changed files in target dirs, explicitly mark status PARTIAL and explain why.\n4) Append/update a ledger file at ops/overnight-artifact-ledger-YYYY-MM-DD.md using ops/ARTIFACT_LEDGER_TEMPLATE.md structure.\n5) Provide top blockers and first 3 actions for morning.\n\nIf no artifacts were created, output exactly: NO_ARTIFACTS_CREATED and explain blockers."
      },
      "delivery": {
        "mode": "announce",
        "channel": "webchat",
        "to": "openclaw-control-ui"
      },
      "state": {
        "nextRunAtMs": 1773201600000
      }
    },
